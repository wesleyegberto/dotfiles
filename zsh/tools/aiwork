#!/bin/bash

# Function to display usage information
usage() {
    echo "🎓 Usage: aiwork <feature_branch_name> [base_branch]"
    echo "Example: aiwork new-feature main"
    echo "If base_branch is not provided, it will use the current branch."
}

if [ -z "$1" ]; then
    usage
    exit 1
fi

FEATURE_BRANCH=$1
CURRENT_BRANCH=$(git branch --show-current)
BASE_BRANCH=${2:-$CURRENT_BRANCH}

# Validation: check if we are inside a git repository
if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "❌ Error: You are not inside a Git repository."
    exit 1
fi

# Get current project info
PROJECT_ROOT=$(git rev-parse --show-toplevel)
PROJECT_NAME=$(basename "$PROJECT_ROOT")
PARENT_DIR=$(dirname "$PROJECT_ROOT")

# Define naming conventions for directory and session
WORKTREE_NAME="${PROJECT_NAME}-aiwork-${FEATURE_BRANCH}"
TARGET_DIR="${PARENT_DIR}/${PROJECT_NAME}-worktrees/${WORKTREE_NAME}"
SESSION_NAME="$WORKTREE_NAME"

# Check if the target directory already exists
if [ -d "$TARGET_DIR" ]; then
    echo "❌ Error: The directory $TARGET_DIR already exists."
    exit 1
fi

echo "📂 Creating worktree at: $TARGET_DIR"
echo "🌿 Based on branch: $BASE_BRANCH"

# Create the worktree
# -b creates a new branch based on BASE_BRANCH
git worktree add -b "$FEATURE_BRANCH" "$TARGET_DIR" "$BASE_BRANCH"

if [ $? -ne 0 ]; then
    echo "❌ Error: Failed to create git worktree."
    exit 1
fi

echo "🖥️  Configuring Tmux session: $SESSION_NAME"

# Start new Tmux session in background (-d)
# Window 1: src
tmux new-session -d -s "$SESSION_NAME" -n "src" -c "$TARGET_DIR"

# Window 2: ai
tmux new-window -t "$SESSION_NAME:2" -n "ai" -c "$TARGET_DIR"

# Window 3: run
tmux new-window -t "$SESSION_NAME:3" -n "run" -c "$TARGET_DIR"

# Open the tools
tmux send-keys -t "$SESSION_NAME:1" "vim ." C-m
tmux send-keys -t "$SESSION_NAME:2" "claude" C-m

# Focus on the 'ai' window (Window 2)
tmux select-window -t "$SESSION_NAME:2"

# Attach or switch to the session
[[ -n "$TMUX" ]] && change="switch-client" || change="attach-session"
tmux "$change" -t "$SESSION_NAME"

